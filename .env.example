# Untatiz Docker Environment Variables
# 이 파일을 .env로 복사하고 실제 값으로 채우세요
# cp .env.example .env

# ============================================
# Discord Webhook 설정
# ============================================
# Discord 채널 웹훅 URL (Settings > Integrations > Webhooks에서 생성)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# ============================================
# OpenAI API 설정
# ============================================
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================
# Statiz 계정 설정 (JSON 배열 형태)
# ============================================
# 단일 계정 예시:
# STATIZ_ACCOUNTS=[{"user_id":"email@example.com","user_pw":"password"}]
#
# 다중 계정 예시:
# STATIZ_ACCOUNTS=[{"user_id":"email1@example.com","user_pw":"pass1"},{"user_id":"email2@example.com","user_pw":"pass2"}]
STATIZ_ACCOUNTS=[{"user_id":"your_email@example.com","user_pw":"your_password"}]

# ============================================
# 프록시 설정 (선택적, JSON 배열 형태)
# ============================================
# 프록시 없이 사용하려면 빈 배열로 설정:
# STATIZ_PROXIES=[]
#
# 프록시 사용 예시:
# STATIZ_PROXIES=["http://proxy1:8080","socks5://proxy2:1080"]
STATIZ_PROXIES=[]

# ============================================
# Google Service Account (선택적)
# ============================================
# Google Sheets 연동을 위한 서비스 계정 JSON
# 전체 JSON 문자열을 한 줄로 입력
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SERVICE_ACCOUNT_JSON=

# ============================================
# Flask 설정
# ============================================
# 프로덕션 환경에서는 반드시 안전한 랜덤 키로 변경
FLASK_SECRET_KEY=change_this_to_a_secure_random_string
